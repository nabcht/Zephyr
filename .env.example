# Zephyr example configuration

# Choose one provider: ollama, openrouter, or llamacpp
LLM_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# OpenRouter
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=openai/gpt-oss-120b:free

# LlamaCPP
# LLM_PROVIDER=llamacpp
# LLAMACPP_MODEL_PATH=LLM/gemma-4/gemma-4-E4B-it-UD-Q8_K_XL.gguf
# LLAMACPP_N_CTX=32768
# LLAMACPP_N_GPU_LAYERS=-1

# Optional sandbox settings
# SANDBOX_BACKEND=auto
# SANDBOX_DOCKER_IMAGE=python:3.11-slim

# Optional MCP settings
# MCP_ENABLED=false
# EXTERNAL_SUBPROCESS_INTEGRATIONS_ENABLED=true
